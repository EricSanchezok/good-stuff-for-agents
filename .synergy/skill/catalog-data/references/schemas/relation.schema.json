{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Relation Edge",
  "type": "object",
  "required": ["schema_version", "subject", "predicate", "object", "weight", "evidence", "source", "created_at"],
  "properties": {
    "schema_version": { "const": 1 },
    "subject": { "type": "string" },
    "predicate": { "enum": ["same_as", "variant_of", "fork_of", "supersedes", "overlaps_with", "complements", "conflicts_with", "requires_tool", "fits_workflow_stage", "input_enables", "belongs_to_domain"] },
    "object": { "type": "string" },
    "weight": { "type": "number", "minimum": 0, "maximum": 1 },
    "evidence": { "type": "string" },
    "source": { "type": "string" },
    "created_at": { "type": "string" }
  }
}
